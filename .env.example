# ─────────────────────────────────────────────────
# POS-Template — Environment Variables
# ─────────────────────────────────────────────────

# ─── Database ──────────────────────────────────
# Local PostgreSQL (Docker):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/celiapos"
# Neon (production):
# DATABASE_URL="postgresql://user:password@ep-xxx.sa-east-1.aws.neon.tech/dbname?sslmode=require"

# ─── Auth (NextAuth.js v5) ────────────────────
AUTH_SECRET="generate-with: npx auth secret"
AUTH_URL="http://localhost:3000"

# ─── OAuth Providers ──────────────────────────
# GitHub:
NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_GITHUB_CLIENT_SECRET=
# Google:
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=

# ─── Pusher (WebSockets) ─────────────────────
NEXT_PUBLIC_PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ─── AFIP / ARCA ─────────────────────────────
# Cloud Function URL for electronic invoicing:
AFIP_CLOUD_FUNCTION_URL=
